# Copy to `.env` and adjust. All client-exposed vars MUST be prefixed with VITE_.
# Parsed and validated at startup by src/shared/config/env.ts (fails fast if invalid).

# Base URL for API calls. In dev/test this is served by MSW (see plan §4 / Phase 1+).
VITE_API_BASE_URL=/api

# Display name used in the UI.
VITE_APP_NAME=React Zustand Seed
