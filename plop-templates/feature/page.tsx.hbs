import { use{{pascalCase name}}List } from '../api/use-{{kebabCase name}}-list'
import { use{{pascalCase name}}Store } from '../store/{{kebabCase name}}-store'

/** Generated page for the {{kebabCase name}} feature. Add a route to reach it (plan §4.3). */
export const {{pascalCase name}}Page = () => {
  const list = use{{pascalCase name}}List()
  const selectedId = use{{pascalCase name}}Store((s) => s.selectedId)
  const setSelectedId = use{{pascalCase name}}Store((s) => s.setSelectedId)

  return (
    <div className="space-y-4">
      <h1 className="text-2xl font-semibold">{{pascalCase name}}</h1>
      {list.isPending ? (
        <p className="text-muted-foreground text-sm">Loading…</p>
      ) : list.isError ? (
        <p className="text-destructive text-sm">{list.error.message}</p>
      ) : (
        <ul className="space-y-1 text-sm">
          {list.data.map((item) => (
            <li key={item.id}>
              <button
